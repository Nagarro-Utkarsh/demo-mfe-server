<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>MFE Preview</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #0d0f14;
      --surface:     #13161e;
      --surface-2:   #1c2030;
      --border:      #252836;
      --border-2:    #2e3347;
      --accent:      #7c6dfa;
      --accent-dim:  rgba(124, 109, 250, 0.08);
      --green:       #3ecf8e;
      --green-dim:   rgba(62, 207, 142, 0.12);
      --text:        #e8eaf2;
      --text-2:      #9499b0;
      --text-3:      #555a72;
      --sidebar-w:   260px;
      --topbar-h:    52px;
      --statusbar-h: 28px;
      --radius-sm:   6px;
      --radius:      10px;
      --radius-lg:   14px;
    }

    html, body { height: 100%; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow: hidden;
    }

    /* ── Top bar ── */
    .topbar {
      height: var(--topbar-h);
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 18px;
      gap: 14px;
      flex-shrink: 0;
      z-index: 10;
    }
    .topbar__brand { display: flex; align-items: center; gap: 9px; }
    .topbar__icon {
      width: 28px; height: 28px;
      background: var(--accent);
      border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; flex-shrink: 0;
    }
    .topbar__name { font-size: 13px; font-weight: 700; letter-spacing: 0.04em; color: var(--text); }
    .topbar__tag {
      font-size: 10px; font-weight: 600; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--accent);
      background: var(--accent-dim);
      border: 1px solid rgba(124, 109, 250, 0.25);
      padding: 2px 7px; border-radius: 20px;
    }
    .topbar__sep { flex: 1; }
    .topbar__pill {
      display: flex; align-items: center; gap: 6px;
      font-size: 12px; color: var(--text-2);
      background: var(--surface-2); border: 1px solid var(--border);
      padding: 5px 12px; border-radius: 20px;
    }
    .topbar__pill-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--green); box-shadow: 0 0 6px var(--green);
    }

    /* ── Layout ── */
    .layout { display: flex; flex: 1; overflow: hidden; }

    /* ── Sidebar ── */
    .sidebar {
      width: var(--sidebar-w);
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex; flex-direction: column;
      flex-shrink: 0; overflow: hidden;
    }
    .sidebar__head { padding: 16px 16px 10px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .sidebar__head-label {
      font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--text-3);
    }
    .sidebar__count {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 18px; height: 18px; padding: 0 5px;
      background: var(--surface-2); border: 1px solid var(--border-2);
      border-radius: 20px; font-size: 10px; font-weight: 600;
      color: var(--text-2); margin-left: 6px; vertical-align: middle;
    }
    .sidebar__list {
      flex: 1; overflow-y: auto; padding: 10px 10px 16px;
      display: flex; flex-direction: column; gap: 4px;
    }
    .sidebar__list::-webkit-scrollbar { width: 4px; }
    .sidebar__list::-webkit-scrollbar-track { background: transparent; }
    .sidebar__list::-webkit-scrollbar-thumb { background: var(--border-2); border-radius: 4px; }

    /* ── Fragment card ── */
    .frag-card {
      padding: 10px 12px; border-radius: var(--radius);
      border: 1px solid transparent; cursor: pointer;
      transition: background 0.15s, border-color 0.15s; user-select: none;
    }
    .frag-card:hover { background: var(--surface-2); border-color: var(--border); }
    .frag-card.active { background: var(--accent-dim); border-color: rgba(124, 109, 250, 0.3); }
    .frag-card__row { display: flex; align-items: center; gap: 9px; }
    .frag-card__indicator {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--border-2); flex-shrink: 0;
      transition: background 0.15s, box-shadow 0.15s;
    }
    .frag-card.active .frag-card__indicator { background: var(--accent); box-shadow: 0 0 8px var(--accent); }
    .frag-card__label { font-size: 13px; font-weight: 500; color: var(--text-2); transition: color 0.15s; flex: 1; }
    .frag-card.active .frag-card__label { color: var(--text); }
    .frag-card__arrow { font-size: 11px; color: var(--text-3); opacity: 0; transition: opacity 0.15s; }
    .frag-card:hover .frag-card__arrow,
    .frag-card.active .frag-card__arrow { opacity: 1; }
    .frag-card__desc {
      font-size: 11px; color: var(--text-3); margin-top: 4px;
      padding-left: 17px; line-height: 1.5; display: none;
    }
    .frag-card.active .frag-card__desc { display: block; color: var(--text-2); }

    /* ── Main ── */
    .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; background: var(--bg); }

    /* ── Canvas header ── */
    .canvas-header {
      padding: 14px 20px 12px; display: flex; align-items: center;
      justify-content: space-between; flex-shrink: 0;
      border-bottom: 1px solid var(--border); background: var(--surface); gap: 12px;
    }
    .canvas-header__left { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .canvas-header__title {
      font-size: 14px; font-weight: 600; color: var(--text);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .canvas-header__desc { font-size: 11px; color: var(--text-3); }
    .canvas-header__right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }

    .badge {
      font-size: 10px; font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; padding: 3px 9px; border-radius: 20px;
    }
    .badge--ssr    { background: var(--accent-dim); border: 1px solid rgba(124,109,250,0.3); color: var(--accent); }
    .badge--loading { background: var(--green-dim); border: 1px solid rgba(62,207,142,0.25); color: var(--green); }
    .badge--error  { background: rgba(255,77,77,0.08); border: 1px solid rgba(255,77,77,0.25); color: #ff8585; }
    .badge--idle   { background: var(--surface-2); border: 1px solid var(--border-2); color: var(--text-3); }

    /* ── Canvas wrap ── */
    .canvas-wrap {
      flex: 1; overflow: hidden; position: relative;
      margin: 16px; border-radius: var(--radius-lg);
      border: 1px solid var(--border); background: #fff;
    }

    /* ── The iframe IS the canvas — it fills the wrap completely ── */
    #fragment-frame {
      width: 100%; height: 100%;
      border: none; display: block;
      background: #fff;
    }

    /* ── Overlay states (sit on top of the iframe) ── */
    .state {
      position: absolute; inset: 0;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 12px; background: #fff; pointer-events: none;
    }
    .state.hidden { display: none; }
    .state__icon { font-size: 32px; opacity: 0.4; }
    .state__text { font-size: 13px; color: var(--text-3); }

    .spinner {
      width: 22px; height: 22px;
      border: 2px solid var(--border-2);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .error-panel {
      position: absolute; inset: 0; display: none;
      padding: 28px; background: #fff; overflow: auto;
    }
    .error-panel.visible { display: block; }
    .error-panel__title { font-size: 13px; font-weight: 700; color: #e05252; margin-bottom: 8px; }
    .error-panel__body {
      font-size: 12px; color: #888; line-height: 1.7;
      white-space: pre-wrap; font-family: 'SF Mono', 'Fira Code', monospace;
    }

    /* ── Status bar ── */
    .statusbar {
      height: var(--statusbar-h); background: var(--accent);
      display: flex; align-items: center; padding: 0 14px; gap: 16px; flex-shrink: 0;
    }
    .statusbar__item {
      font-size: 11px; font-weight: 500; color: rgba(255,255,255,0.85);
      display: flex; align-items: center; gap: 5px;
    }
    .statusbar__item svg { opacity: 0.7; }

    /* ── Language dropdown ── */
    .lang-dropdown {
      position: relative;
      display: inline-flex;
    }
    .lang-dropdown__toggle {
      display: flex; align-items: center; gap: 6px;
      font-size: 12px; font-weight: 500; color: var(--text-2);
      background: var(--surface-2); border: 1px solid var(--border);
      padding: 5px 12px; border-radius: 20px;
      cursor: pointer; transition: border-color 0.15s, color 0.15s;
      user-select: none;
    }
    .lang-dropdown__toggle:hover { border-color: var(--border-2); color: var(--text); }
    .lang-dropdown__toggle.open { border-color: var(--accent); color: var(--text); }
    .lang-dropdown__arrow {
      font-size: 9px; transition: transform 0.2s;
    }
    .lang-dropdown__toggle.open .lang-dropdown__arrow { transform: rotate(180deg); }
    .lang-dropdown__menu {
      display: none;
      position: absolute; top: calc(100% + 6px); right: 0;
      min-width: 160px;
      background: var(--surface); border: 1px solid var(--border-2);
      border-radius: var(--radius); padding: 6px 0;
      box-shadow: 0 8px 24px rgba(0,0,0,0.35);
      z-index: 100; max-height: 240px; overflow-y: auto;
    }
    .lang-dropdown__menu.visible { display: block; }
    .lang-dropdown__menu::-webkit-scrollbar { width: 4px; }
    .lang-dropdown__menu::-webkit-scrollbar-track { background: transparent; }
    .lang-dropdown__menu::-webkit-scrollbar-thumb { background: var(--border-2); border-radius: 4px; }
    .lang-dropdown__item {
      display: flex; align-items: center; gap: 8px;
      padding: 7px 14px; font-size: 12px; color: var(--text-2);
      cursor: pointer; transition: background 0.12s, color 0.12s;
    }
    .lang-dropdown__item:hover { background: var(--surface-2); color: var(--text); }
    .lang-dropdown__item.selected { color: var(--accent); font-weight: 600; }
  </style>
</head>
<body>

  <!-- Top bar -->
  <div class="topbar">
    <div class="topbar__brand">
      <div class="topbar__icon">⬡</div>
      <span class="topbar__name">MFE Preview</span>
      <span class="topbar__tag">Dev</span>
    </div>
    <div class="topbar__sep"></div>
    <div class="topbar__pill">
      <span class="topbar__pill-dot"></span>
      Server running
    </div>
  </div>

  <!-- Body -->
  <div class="layout">

    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar__head">
        <span class="sidebar__head-label">
          Fragments
          <span class="sidebar__count">{{fragments.length}}</span>
        </span>
      </div>
      <div class="sidebar__list" id="nav">
        {{#each fragments}}
          <div class="frag-card" data-fragment="{{this.name}}">
            <div class="frag-card__row">
              <span class="frag-card__indicator"></span>
              <span class="frag-card__label">{{this.label}}</span>
              <span class="frag-card__arrow">›</span>
            </div>
            {{#if this.description}}
              <div class="frag-card__desc">{{this.description}}</div>
            {{/if}}
          </div>
        {{/each}}
      </div>
    </aside>

    <!-- Main -->
    <main class="main">

      <!-- Canvas header -->
      <div class="canvas-header">
        <div class="canvas-header__left">
          <div class="canvas-header__title" id="canvas-title">—</div>
          <div class="canvas-header__desc"  id="canvas-desc"></div>
        </div>
      </div>

      <!-- Canvas — fragment renders inside an iframe for full CSS isolation -->
      <div class="canvas-wrap">

        <!--
          The iframe src is set to /standalone/:pageName which is a complete
          self-contained HTML page. This gives the fragment its own document,
          its own html/body elements, and zero CSS bleed from the shell.
        -->
        <iframe id="fragment-frame" title="Fragment preview"></iframe>

        <!-- Empty state (shown before any fragment is selected) -->
        <div class="state" id="state-idle">
          <div class="state__icon">◫</div>
          <div class="state__text">Select a fragment from the sidebar</div>
        </div>

        <!-- Loading state -->
        <div class="state hidden" id="state-loading">
          <div class="spinner"></div>
          <div class="state__text">Loading fragment…</div>
        </div>

        <!-- Error state -->
        <div class="error-panel" id="state-error">
          <div class="error-panel__title" id="error-title">Error</div>
          <div class="error-panel__body"  id="error-body"></div>
        </div>

      </div>
    </main>
  </div>

  <!-- Status bar -->
  <div class="statusbar">
    <div class="statusbar__item">
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
        <circle cx="5" cy="5" r="4" stroke="white" stroke-width="1.2"/>
        <path d="M5 3v2.5l1.5 1" stroke="white" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <span id="sb-fragment">No fragment loaded</span>
    </div>
    <div class="statusbar__item">
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
        <rect x="1" y="1" width="8" height="8" rx="1.5" stroke="white" stroke-width="1.2"/>
        <path d="M3 5h4M5 3v4" stroke="white" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      localhost:{{port}}
    </div>
  </div>

  <script>
    const META = {
      {{#each fragments}}
        '{{this.name}}': { label: '{{this.label}}', description: '{{this.description}}' },
      {{/each}}
    };
    const DEFAULT = '{{defaultFragment}}';

    // ── DOM refs ──────────────────────────────────────────────────────────
    const frame       = document.getElementById('fragment-frame');
    const stateIdle   = document.getElementById('state-idle');
    const stateLoad   = document.getElementById('state-loading');
    const stateError  = document.getElementById('state-error');
    const errorTitle  = document.getElementById('error-title');
    const errorBody   = document.getElementById('error-body');
    const canvasTitle = document.getElementById('canvas-title');
    const canvasDesc  = document.getElementById('canvas-desc');
    const statusBadge = document.getElementById('status-badge');
    const sbFragment  = document.getElementById('sb-fragment');

    // ── State helpers ─────────────────────────────────────────────────────
    function setState(s) {
      stateIdle.classList.toggle('hidden', s !== 'idle');
      stateLoad.classList.toggle('hidden', s !== 'loading');
      stateError.classList.toggle('visible', s === 'error');

      const map = {
        idle:    ['badge--idle',    'Idle'],
        loading: ['badge--loading', 'Loading'],
        ready:   ['badge--ssr',     'SSR'],
        error:   ['badge--error',   'Error'],
      };
      if (statusBadge) {
        statusBadge.className   = `badge ${map[s][0]}`;
        statusBadge.textContent = map[s][1];
      }
    }

    // ── Load fragment via iframe ──────────────────────────────────────────
    // Point the iframe at /standalone/:name — a complete self-contained HTML
    // page served by the same Fastify server. The iframe gets its own document
    // with its own html/body, so the shell CSS never touches the fragment.
    let currentFragment = null;
    function loadFragment(name) {
      currentFragment = name;
      const meta = META[name] || {};

      // Update nav
      document.querySelectorAll('.frag-card').forEach(el =>
        el.classList.toggle('active', el.dataset.fragment === name)
      );

      // Update header
      canvasTitle.textContent = meta.label || name;
      canvasDesc.textContent  = meta.description || '';
      sbFragment.textContent  = meta.label || name;

      setState('loading');

      // Hide the iframe while loading to avoid a flash of old content
      frame.style.visibility = 'hidden';

      frame.onload = () => {
        frame.style.visibility = 'visible';
        setState('ready');
      };

      frame.onerror = () => {
        errorTitle.textContent = `Failed to load "${name}"`;
        errorBody.textContent  = 'The standalone route returned an error.';
        setState('error');
      };

      frame.src = `/standalone/${name}/${selectedLang}`;

      // Update browser URL so back/forward works
      history.pushState({ fragment: name }, '', `/preview/${name}`);
    }

    // ── Nav clicks ────────────────────────────────────────────────────────
    document.getElementById('nav').addEventListener('click', e => {
      const card = e.target.closest('.frag-card');
      if (card?.dataset.fragment) loadFragment(card.dataset.fragment);
    });

    // ── Browser back / forward ────────────────────────────────────────────
    window.addEventListener('popstate', e => {
      if (e.state?.fragment) loadFragment(e.state.fragment);
    });

    const selectedLang = 'en-US';

    // ── Initial load ──────────────────────────────────────────────────────
    const initial = '{{initialFragment}}' !== '' ? '{{initialFragment}}' : DEFAULT;
    loadFragment(initial);
  </script>

</body>
</html>
